# Backend Environment Variables
# Энэ файлыг .env болгон хуулаад утгуудыг тохируулна уу

PORT=3000
NODE_ENV=production

# MongoDB Atlas connection string
# Жишээ: mongodb+srv://username:password@cluster.mongodb.net/car-service
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/car-service

# JWT Secret — нууц, урт, санамсаргүй тэмдэгтүүд ашиглана уу
# Жишээ: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_KEY

# Frontend URL (Vercel дээр deploy хийсний дараа оруулна)
# Олон URL-уудыг таслалаар тусгаарлана: https://app1.vercel.app,https://app2.vercel.app
FRONTEND_URL=https://YOUR_APP.vercel.app

# BYL Payment Gateway (өөрчлөхгүй байж болно)
BYL_PROJECT_ID=525
BYL_API_KEY=YOUR_BYL_API_KEY

# Cloudinary - Сэлбэгийн зураг хадгалах үйлчилгээ
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_API_KEY
CLOUDINARY_API_SECRET=YOUR_API_SECRET
